          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT * FROM ( \r\n  SELECT \r\n    sensor_id, \r\n    value AS \"Target Temperature\", \r\n    measured_at AS \"time\" \r\n    FROM measurement WHERE sensor_id = 'Chiller-T' \r\n    ORDER BY measured_at \r\n    DESC \r\n    LIMIT 10000 \r\n  ) \r\nAS sub ORDER BY \"time\" ASC",
          "refId": "Target",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
