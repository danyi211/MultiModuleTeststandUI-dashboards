        },
        {
          "dataset": "PLC_COLLECT",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "grafana_postgresql_datasource_PLC"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT \r\n    measured_at AS \"time\",\r\n    MAX(CASE WHEN sensor_id = 'RTD-01' THEN value END) AS \"RTD-01\",\r\n    MAX(CASE WHEN sensor_id = 'RTD-02' THEN value END) AS \"RTD-02\",\r\n    MAX(CASE WHEN sensor_id = 'RTD-03' THEN value END) AS \"RTD-03\",\r\n    MAX(CASE WHEN sensor_id = 'RTD-04' THEN value END) AS \"RTD-04\",\r\n    MAX(CASE WHEN sensor_id = 'RTD-05' THEN value END) AS \"RTD-05\",\r\n    MAX(CASE WHEN sensor_id = 'RTD-06' THEN value END) AS \"RTD-06\",\r\n    MAX(CASE WHEN sensor_id = 'RTD-07' THEN value END) AS \"RTD-07\",\r\n    MAX(CASE WHEN sensor_id = 'RTD-08' THEN value END) AS \"RTD-08\"\r\nFROM measurement\r\nWHERE sensor_id IN ('RTD-01', 'RTD-02', 'RTD-03', 'RTD-04', 'RTD-05', 'RTD-06', 'RTD-07', 'RTD-08')\r\n  AND $__timeFilter(measured_at) \r\nGROUP BY measured_at\r\nORDER BY measured_at ASC\r\nLIMIT 10000;",
          "refId": "RTD",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
