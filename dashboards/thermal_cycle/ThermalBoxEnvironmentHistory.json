          "format": "table",
          "rawQuery": true,
          "rawSql": "        WITH latest_qc_summary AS (\n            SELECT DISTINCT ON (module_name) *\n            FROM module_qc_summary\n            ORDER BY module_name, mod_qc_no DESC\n        ), \n\n        latest_iv_test AS (\n            SELECT DISTINCT ON (mod_ivtest_no) *\n            FROM module_iv_test\n            WHERE meas_v IS NOT NULL AND meas_i IS NOT NULL\n            AND array_length(meas_v, 1) = array_length(meas_i, 1)\n            AND module_name = '${selected_module_name}'\n            AND status = 8\n            ORDER BY mod_ivtest_no DESC\n        )\n\n        SELECT module_name, (date_test + time_test) AS test_timestamp,  rel_hum, temp_c, inspector\n        FROM latest_iv_test\n        ORDER BY mod_ivtest_no DESC;\n        \n",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
