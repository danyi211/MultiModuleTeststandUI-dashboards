      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "mac_postgres_db"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "\n        WITH latest_qc_summary AS (\n            SELECT DISTINCT ON (module_name) *\n            FROM module_qc_summary\n            ORDER BY module_name, mod_qc_no DESC\n        ), \n\n        latest_iv_test AS (\n            SELECT DISTINCT ON (mod_ivtest_no) *\n            FROM module_iv_test\n            WHERE meas_v IS NOT NULL AND meas_i IS NOT NULL\n\t\t\tAND (temp_c::float ${temp_range})\n\t\t\tAND (rel_hum::float ${humi_range})\n            AND temp_c ~ '^[-+]?[0-9]+(\\.[0-9]+)?$'\n            AND rel_hum ~ '^[-+]?[0-9]+(\\.[0-9]+)?$'\n            AND array_length(meas_v, 1) = array_length(meas_i, 1)\n\t\t\tAND module_name = '${selected_module_name}'\n            ORDER BY mod_ivtest_no DESC\n        ),\n\n\n        filtered_iv AS (\n        SELECT *,\n            meas_i[array_length(meas_i, 1)] AS i_last\n        FROM module_iv_test\n        WHERE\n            mod_ivtest_no IN (SELECT mod_ivtest_no FROM latest_iv_test)\n        ),\n\n        best_per_module AS (\n        SELECT DISTINCT ON (filtered_iv.mod_ivtest_no) *\n        FROM filtered_iv\n\n        ORDER BY filtered_iv.mod_ivtest_no, i_last DESC\n        ),\n\n        unnested AS (\n        SELECT \n             mod_ivtest_no,\n        module_name,\n        rel_hum,\n        temp_c,\n        date_test,\n        status_desc,\n            ABS(v) as v,\n            i\n        FROM best_per_module,\n        UNNEST(meas_v, meas_i) AS t(v, i)\n        )\n\n        SELECT \n            concat_ws(' | ',\n        module_name,\n        'RH=' || rel_hum,\n        'T=' || temp_c,\n        status_desc,\n        to_char(date_test, 'YYYY-MM-DD')\n    ) AS legend_label,\n    v,\n    i\n        FROM unnested\n        ORDER BY mod_ivtest_no ASC;\n        ",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Single Module IV Curve",
